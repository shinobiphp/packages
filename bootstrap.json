[
  {
    "name": "core",
    "slug": "core",
    "namespace": "Shinobi\\",
    "description": "The foundational capability layer for the Shinobi platform.",
    "version": "1.0.0",
    "requires": "php@>=8.4",
    "src": {
      "Attributes": [
        {
          "filename": "Discoverable.php",
          "uses": ["Attribute"],
          "attributes": ["Attribute(Attribute::TARGET_CLASS)"],
          "body": "    public function __construct(public string $alias = '') {}"
        },
        {
          "filename": "Capability.php",
          "uses": ["Attribute"],
          "attributes": ["Attribute(Attribute::TARGET_CLASS|Attribute::TARGET_METHOD)"]
        },
        "Intent.php",
        "URI.php"
      ],
      "Contracts": [
        {
          "filename": "CapabilityInterface.php",
          "type": "interface",
          "body": "    public function execute(array $payload): mixed;"
        },
        {
          "filename": "ForgeInterface.php",
          "type": "interface",
          "body": "    public function manifest(string $spec): void;"
        }
      ],
      "Traits": [
        "HasMetadata.php",
        "Evolvable.php"
      ]
    }
  },
  {
    "name": "dna",
    "slug": "dna",
    "namespace": "Shinobi\\DNA\\",
    "description": "The evolutionary engine for self-optimizing capabilities.",
    "version": "1.0.0",
    "requires": "php@>=8.4,shinobiphp/core",
    "src": {
      "Sequencing": [
        {
          "filename": "Genome.php",
          "uses": ["Shinobi\\Attributes\\Discoverable"],
          "attributes": ["Discoverable('dna.genome')"],
          "body": "    public function __construct(\n        public array $map = [],\n        public bool $isMutable = true\n    ) {}"
        },
        "Hydrator.php"
      ],
      "DTO": [
        {
          "filename": "ManifestDTO.php",
          "body": "    public string $name { get => $this->name; set => strtolower($v); }\n    public string $version { get; set; }"
        }
      ]
    }
  }
]
